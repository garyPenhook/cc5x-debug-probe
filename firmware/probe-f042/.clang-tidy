# clang-tidy config for the F042 probe firmware.
#
# Run against the compile DB produced by the host 'tests' preset (portable
# sources) or the 'firmware' cross preset (needs vendor/ + CMSIS):
#   cmake --preset tests           # writes build-tests/compile_commands.json
#   clang-tidy -p build-tests src/relay.c src/usb_desc.c
#
# Focus: real-bug checks (clang-analyzer, bugprone, cert) plus a light
# readability pass. Whole check groups that fight low-level register/MMIO
# firmware are disabled rather than littering the code with NOLINTs.
Checks: >
  clang-analyzer-*,
  bugprone-*,
  cert-*,
  misc-*,
  performance-*,
  readability-*,
  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-function-cognitive-complexity,
  -readability-isolate-declaration,
  -readability-braces-around-statements,
  -readability-uppercase-literal-suffix,
  -readability-math-missing-parentheses,
  -readability-redundant-declaration,
  -bugprone-easily-swappable-parameters,
  -bugprone-assignment-in-if-condition,
  -cert-dcl16-c,
  -misc-no-recursion,
  -misc-include-cleaner

WarningsAsErrors: ''
HeaderFilterRegex: '.*/src/.*\.h$'
FormatStyle: file
